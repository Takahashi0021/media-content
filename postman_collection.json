{
  "info": {
    "name": "Media Content API - Full with Favorites & Reviews",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Favorites",
      "item": [
        {
          "name": "Add Movie to Favorites",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"movie_id\": 1\n}"
            },
            "url": {"raw": "http://localhost:8080/api/favorites"}
          }
        },
        {
          "name": "Add Series to Favorites",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"series_id\": 1\n}"
            },
            "url": {"raw": "http://localhost:8080/api/favorites"}
          }
        },
        {
          "name": "Get My Favorites",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "http://localhost:8080/api/favorites"}
          }
        },
        {
          "name": "Remove Favorite",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "http://localhost:8080/api/favorites/1"}
          }
        },
        {
          "name": "Get Movie Favorites Count",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8080/api/favorites/movies/1/count"}
          }
        }
      ]
    },
    {
      "name": "Reviews & Ratings",
      "item": [
        {
          "name": "Create Movie Review",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"movie_id\": 1,\n  \"rating\": 9,\n  \"comment\": \"Amazing movie! Highly recommend.\"\n}"
            },
            "url": {"raw": "http://localhost:8080/api/reviews"}
          }
        },
        {
          "name": "Create Series Review",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"series_id\": 1,\n  \"rating\": 10,\n  \"comment\": \"Best series ever!\"\n}"
            },
            "url": {"raw": "http://localhost:8080/api/reviews"}
          }
        },
        {
          "name": "Get Movie Reviews",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8080/api/reviews?movie_id=1&page=1&limit=10"}
          }
        },
        {
          "name": "Get Series Reviews",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8080/api/reviews?series_id=1&page=1&limit=10"}
          }
        },
        {
          "name": "Update Review",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Authorization", "value": "Bearer {{token}}"},
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 10,\n  \"comment\": \"Even better on second watch!\"\n}"
            },
            "url": {"raw": "http://localhost:8080/api/reviews/1"}
          }
        },
        {
          "name": "Like Review",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "http://localhost:8080/api/reviews/1/like"}
          }
        },
        {
          "name": "Delete Review",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {"raw": "http://localhost:8080/api/reviews/1"}
          }
        },
        {
          "name": "Get Average Rating for Movie",
          "request": {
            "method": "GET",
            "url": {"raw": "http://localhost:8080/api/reviews/rating/average?movie_id=1"}
          }
        }
      ]
    }
  ],
  "variable": [{"key": "token", "value": "", "type": "string"}]
}